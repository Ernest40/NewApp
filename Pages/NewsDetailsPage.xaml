<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Pages.NewsDetailsPage"
             Title="News Details">

    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="12">

            <Image x:Name="ImgNews"
                   HeightRequest="220"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"/>

            <Label x:Name="LblTitle"
                   FontSize="22"
                   FontAttributes="Bold"/>

            <Label x:Name="LblContent"
                   FontSize="16"
                   LineHeight="1.3"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>